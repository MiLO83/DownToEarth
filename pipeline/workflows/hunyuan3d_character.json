{
  "1": {
    "class_type": "LoadImage",
    "inputs": { "image": "char_front.png" },
    "_meta": { "title": "Load Front" }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": { "image": "char_back.png" },
    "_meta": { "title": "Load Back" }
  },
  "10": {
    "class_type": "Hy3DModelLoader",
    "inputs": {
      "model": "hunyuan3d-dit-v2-0.safetensors",
      "attention_mode": "sdpa"
    },
    "_meta": { "title": "Load Hy3D DiT Model" }
  },
  "11": {
    "class_type": "DownloadAndLoadHy3DPaintModel",
    "inputs": { "model": "hunyuan3d-paint-v2-0" },
    "_meta": { "title": "Load Hy3D Paint Model" }
  },
  "20": {
    "class_type": "Hy3DGenerateMeshMultiView",
    "inputs": {
      "pipeline": ["10", 0],
      "guidance_scale": 5.5,
      "steps": 30,
      "seed": 42,
      "front": ["1", 0],
      "back":  ["2", 0]
    },
    "_meta": { "title": "Generate Mesh (Multi-View)" }
  },
  "30": {
    "class_type": "Hy3DVAEDecode",
    "inputs": {
      "vae": ["10", 1],
      "latents": ["20", 0],
      "box_v": 1.01,
      "octree_resolution": 384,
      "num_chunks": 8000,
      "mc_level": 0.0,
      "mc_algo": "mc"
    },
    "_meta": { "title": "VAE Decode → Trimesh" }
  },
  "40": {
    "class_type": "Hy3DPostprocessMesh",
    "inputs": {
      "trimesh": ["30", 0],
      "remove_floaters": true,
      "remove_degenerate_faces": true,
      "reduce_faces": true,
      "max_facenum": 30000,
      "smooth_normals": false
    },
    "_meta": { "title": "Postprocess Mesh" }
  },
  "45": {
    "class_type": "Hy3DMeshUVWrap",
    "inputs": { "trimesh": ["40", 0] },
    "_meta": { "title": "UV Wrap" }
  },
  "50": {
    "class_type": "Hy3DCameraConfig",
    "inputs": {
      "camera_azimuths":   "0, 90, 180, 270, 0, 180",
      "camera_elevations": "0, 0, 0, 0, 90, -90",
      "view_weights":      "1, 0.1, 0.5, 0.1, 0.05, 0.05",
      "camera_distance": 1.45,
      "ortho_scale": 1.2
    },
    "_meta": { "title": "Camera Config" }
  },
  "55": {
    "class_type": "Hy3DRenderMultiView",
    "inputs": {
      "trimesh": ["45", 0],
      "render_size": 1024,
      "texture_size": 1024,
      "camera_config": ["50", 0],
      "normal_space": "world"
    },
    "_meta": { "title": "Render Multi-View" }
  },
  "60": {
    "class_type": "Hy3DSampleMultiView",
    "inputs": {
      "pipeline": ["11", 0],
      "ref_image": ["1", 0],
      "normal_maps": ["55", 0],
      "position_maps": ["55", 1],
      "view_size": 512,
      "steps": 30,
      "seed": 42,
      "camera_config": ["50", 0]
    },
    "_meta": { "title": "Sample Multi-View Textures" }
  },
  "65": {
    "class_type": "Hy3DBakeFromMultiview",
    "inputs": {
      "images": ["60", 0],
      "renderer": ["55", 2],
      "camera_config": ["50", 0]
    },
    "_meta": { "title": "Bake → UV Texture" }
  },
  "70": {
    "class_type": "Hy3DApplyTexture",
    "inputs": {
      "texture": ["65", 0],
      "renderer": ["65", 2]
    },
    "_meta": { "title": "Apply Texture" }
  },
  "80": {
    "class_type": "Hy3DExportMesh",
    "inputs": {
      "trimesh": ["70", 0],
      "filename_prefix": "downtoearth/character",
      "file_format": "glb"
    },
    "_meta": { "title": "Export Textured GLB" }
  }
}
