{
  "_comment": "Character reference image generation — same shape as juggernaut_scene.json but tuned for character framing (portrait composition, full body in frame, neutral background).",
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "Juggernaut-XL_v9_RunDiffusionPhoto_v2.safetensors" },
    "_meta": { "title": "Load Checkpoint" }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "full body portrait, front view, character sheet, neutral gray background, JRPG character, soft studio lighting", "clip": ["1", 1] },
    "_meta": { "title": "Positive Prompt" }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "blurry, deformed, multiple people, side view, three quarter view", "clip": ["1", 1] },
    "_meta": { "title": "Negative Prompt" }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": { "width": 832, "height": 1216, "batch_size": 1 },
    "_meta": { "title": "Empty Latent" }
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 42,
      "steps": 30,
      "cfg": 6.5,
      "sampler_name": "dpmpp_2m_sde_gpu",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["1", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0]
    },
    "_meta": { "title": "KSampler" }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["5", 0], "vae": ["1", 2] },
    "_meta": { "title": "VAE Decode" }
  },
  "7": {
    "class_type": "SaveImage",
    "inputs": { "filename_prefix": "downtoearth/char_ref", "images": ["6", 0] },
    "_meta": { "title": "Save Image" }
  }
}
